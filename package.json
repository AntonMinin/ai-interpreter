{
  "name": "ai-interpreter",
  "version": "0.1.0-alpha",
  "description": "Free, source-available real-time AI interpreter for online meetings",
  "main": "out/main/index.js",
  "author": "Anton Minin Baranovskii",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/anton-minin/ai-interpreter#readme",
  "bugs": {
    "url": "https://github.com/anton-minin/ai-interpreter/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anton-minin/ai-interpreter.git"
  },
  "keywords": [
    "interpreter",
    "translation",
    "speech-to-text",
    "text-to-speech",
    "zoom",
    "google-meet",
    "microsoft-teams",
    "electron",
    "ai"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-vite build && electron-builder --win",
    "dist:dir": "electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
