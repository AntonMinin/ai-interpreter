# API keys are normally entered inside the app (Settings -> API keys) and stored
# encrypted with Windows DPAPI. These environment variables are a convenience for
# development only; they are read at startup if no key is saved in the app.

# OpenAI: speech recognition, translation and text-to-speech
OPENAI_API_KEY=

# Anthropic: optional, used when Claude is selected as the translation provider
ANTHROPIC_API_KEY=
